# Copy to .env.local and fill in real values. NEVER commit .env.local.

WP_GRAPHQL_URL=https://your-wordpress-host/graphql

# Required for Google/Zalo OAuth state signing (generate: openssl rand -base64 32)
OAUTH_STATE_HMAC_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Public origin of this Next.js app (no trailing slash). Production: https://configsdns.com
# Rebuild app after changing. OAuth also uses x-forwarded-* on production when behind proxy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Zalo Developer Console — Callback URL must match exactly:
#   https://configsdns.com/api/auth/zalo/callback
#   http://localhost:3000/api/auth/zalo/callback  (dev only)

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-CHANGE_ME

# Zalo OAuth — https://developers.zalo.me/
ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=CHANGE_ME

# Zalo domain verification meta content (optional)
NEXT_PUBLIC_ZALO_SITE_VERIFICATION=

# Required in production (comma-separated origins, no * wildcard)
# Production: INTERNAL_API_ALLOWED_ORIGINS=https://configsdns.com
# Local dev:   INTERNAL_API_ALLOWED_ORIGINS=http://localhost:3000,https://configsdns.com
