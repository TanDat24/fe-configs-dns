# Production environment template — copy to hosting secrets manager / .env.production.local
# NEVER commit filled values to git.

NODE_ENV=production

WP_GRAPHQL_URL=https://tbayapi.configsdns.com/graphql

# Required — generate new after any leak: openssl rand -base64 32
OAUTH_STATE_HMAC_SECRET=ROTATE_ME

# Must match public URL (no trailing slash). Rebuild Next.js after change.
NEXT_PUBLIC_SITE_URL=https://configsdns.com

# Required in production — comma-separated, NO wildcards, NO localhost
INTERNAL_API_ALLOWED_ORIGINS=https://configsdns.com

GOOGLE_CLIENT_ID=ROTATE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ROTATE_ME

ZALO_APP_ID=ROTATE_ME
ZALO_APP_SECRET=ROTATE_ME

NEXT_PUBLIC_ZALO_SITE_VERIFICATION=

# Optional: force Secure cookies behind TLS-terminating proxy
# FORCE_SECURE_AUTH_COOKIE=1
